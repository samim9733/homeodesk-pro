    "html": "<html lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" prefix=\"og: http://ogp.me/ns# fb: http://ogp.me/ns/fb#\"><head>\n    \n<link rel=\"preload\" as=\"style\" href=\"/assets/html/third-party/bootstrap-4.3.1/css/bootstrap.min.css\">\n<link rel=\"prefetch\" as=\"style\" href=\"/assets/html/third-party/bootstrap-4.3.1/css/bootstrap-darkly.min.css\">\n<link rel=\"preload\" as=\"style\" href=\"/assets/html/mystyle.css\">\n\n<meta charset=\"utf-8\">\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n\n<meta property=\"og:image\" content=\"https://www.oorep.com/assets/html/img/oorep_screenshot.jpg\">\n<meta property=\"og:image:secure_url\" content=\"https://www.oorep.com/assets/html/img/oorep_screenshot.jpg\">\n<meta property=\"og:description\" content=\"Free online repertory of homeopathy that requires only a web browser to run. Features many of the classical repertories, such as Kent, Boger, Hering, etc.\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"OOREP - open online homeopathic repertory\">\n\n<meta name=\"description\" content=\"Free online repertory of homeopathy that requires only a web browser to run. Features many of the classical repertories, such as Kent, Boger, Hering, etc.\">\n<meta name=\"keywords\" content=\"oorep, online, repertory, homeopathy, repertorization, kent\">\n\n<link id=\"darktheme\" rel=\"stylesheet\" href=\"/assets/html/third-party/bootstrap-4.3.1/css/bootstrap-darkly.min.css\" disabled=\"\">\n<link id=\"normaltheme\" rel=\"stylesheet\" href=\"/assets/html/third-party/bootstrap-4.3.1/css/bootstrap.min.css\">\n\n<script src=\"/assets/html/third-party/jquery-3.5.1.min.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/assets/html/third-party/aos-master/dist/aos.css\">\n<script src=\"/assets/html/third-party/aos-master/dist/aos.js\"></script>\n\n<link rel=\"stylesheet\" href=\"/assets/html/mystyle.css\">\n\n<noscript>\n    <!-- https://githu